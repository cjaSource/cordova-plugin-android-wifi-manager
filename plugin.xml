<?xml version="1.0" encoding="UTF-8"?>

<plugin id="cordova-plugin-android-wifi-manager"
        version="1.0.0"
        xmlns="http://apache.org/cordova/ns/plugins/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android">

    <name>AndroidWifiManager</name>
    <description>Cordova Android Wifi Manager</description>
    <license>MIT</license>

    <!-- JS interface -->
    <js-module src="www/WifiManager.js" name="WifiManager">
        <clobbers target="cordova.plugins.WifiManager" />
    </js-module>

    <platform name="android">

        <!-- Register native plugin -->
        <config-file target="res/xml/config.xml" parent="/*">
            <feature name="WifiManager">
                <param name="android-package"
                       value="com.something.WifiManagerPlugin" />
            </feature>
        </config-file>

        <!-- Android permissions -->
        <config-file target="AndroidManifest.xml" parent="/*">

            <!-- Core WiFi -->
            <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
            <uses-permission android:name="android.permission.CHANGE_WIFI_STATE"/>

            <!-- Network -->
            <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
            <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE"/>

            <!-- Internet -->
            <uses-permission android:name="android.permission.INTERNET"/>

            <!-- Required for WiFi scanning (Android 6+) -->
            <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
            <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>

            <!-- Android 13+ WiFi scan -->
            <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
                android:usesPermissionFlags="neverForLocation"/>

            <!-- Multicast -->
            <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE"/>

            <!-- Optional but useful -->
            <uses-permission android:name="android.permission.WAKE_LOCK"/>
            <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>

        </config-file>

        <!-- Native Java file -->
        <source-file src="src/android/WifiManagerPlugin.java"
                     target-dir="src/com/something/" />

    </platform>

</plugin>
